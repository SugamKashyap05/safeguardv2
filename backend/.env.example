NODE_ENV=development
PORT=5000

# Backend Environment Variables

# Supabase Auth (Used for OAuth and session verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Prisma Database Connection (Connects to Supabase PostgreSQL)
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres?pgbouncer=true"
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# External Services
CORS_ORIGIN=http://localhost:5173
YOUTUBE_API_KEY=your_google_cloud_api_key
YOUTUBE_API_QUOTA_LIMIT=10000

# Security
SESSION_SECRET=your_random_session_secret
JWT_SECRET=your_child_jwt_secret

# Email Service
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
